# Test database URL — must point to a dedicated test database, NOT the dev database.
# Create it once with: docker exec -it demo-project-db psql -U postgres -c "CREATE DATABASE demo_project_test;"
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/demo_project_test

# Password for the test user created by Playwright's global setup.
# The test user email is always e2e-test@better-bookkeeping.test.
E2E_TEST_PASSWORD=password123
